// Worktree-aware devcontainer config.
//
// Mount layout:
//   /x/workspace       — the active directory (worktree or main repo)
//   /x/ml-reentry-mlir — the main repo, mounted as a sibling so git worktree
//                        relative paths (e.g., `gitdir: ../ml-reentry-mlir/.git/...`)
//                        resolve correctly inside the container.
//   /x/cache           — persistent host-side cache (build/, ccache, uv venv).
//                        Worktree-independent; survives image rebuilds.
//   /x/data            — persistent host-side datasets (Planetoid, OGB).
//
// Host paths for cache/data are siblings of the workspace by default. To
// relocate, change the two `mounts` entries below and (if you want a different
// container path) the GNNC_CACHE_DIR / GNNC_DATA_DIR vars in Dockerfile.
//
// Dockerfile WORKDIR is /x/workspace.
{
  "name": "ml-reentry-mlir",
  "build": {
    "dockerfile": "Dockerfile"
  },

  // Mount the active directory (worktree or main repo) at a static path.
  "workspaceMount": "source=${localWorkspaceFolder},target=/x/workspace,type=bind",
  "workspaceFolder": "/x/workspace",

  // GPU passthrough. Requires NVIDIA Container Toolkit installed on the host
  // (already present and registered as a Docker runtime on this WSL install).
  "runArgs": ["--gpus=all"],

  // Tell Claude Code the host-side workspace path so setup-claude.sh can
  // create the correct project-key symlink.
  "containerEnv": {
    "HOST_WORKSPACE_FOLDER": "${localWorkspaceFolder}"
  },

  "mounts": [
    // Main repo sibling so .git relative paths resolve.
    // When opened from the main repo itself, this is the same directory
    // as the workspace mount — harmless.
    "source=${localWorkspaceFolder}/../ml-reentry-mlir,target=/x/ml-reentry-mlir,type=bind",
    // Persistent build/uv cache. 40-60 GB once LLVM is built.
    "source=${localWorkspaceFolder}/../ml-reentry-mlir-cache,target=/x/cache,type=bind",
    // Persistent dataset storage.
    "source=${localWorkspaceFolder}/../ml-reentry-mlir-data,target=/x/data,type=bind",
    // Claude Code shared config (credentials, settings, CLAUDE.md).
    "source=${localEnv:HOME}/.claude,target=/mnt/claude/config,type=bind",
    // Claude Code project state (session history, memory). Separate mount
    // so the setup script can symlink per-project without touching config.
    "source=${localEnv:HOME}/.claude/projects,target=/mnt/claude/projects,type=bind"
  ],

  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  // Ensure the host-side project directory exists before the container starts.
  "initializeCommand": "mkdir -p \"$HOME/.claude/projects/$(echo \"$PWD\" | tr '/' '-')\" \"$PWD/../ml-reentry-mlir-cache\" \"$PWD/../ml-reentry-mlir-data\"",

  // Sync Python deps into /x/cache/venv. Incremental across image rebuilds
  // because the venv lives on the persistent cache mount.
  "postCreateCommand": "uv sync --extra dev",

  // Wire up Claude Code config and project state inside the container.
  "postStartCommand": ".devcontainer/setup-claude.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "llvm-vs-code-extensions.vscode-mlir",
        "ms-vscode.cmake-tools"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/x/cache/venv/bin/python",
        "python.analysis.typeCheckingMode": "off"
      }
    }
  }
}
